# Storage (SQLite — no Docker, no daemon)
SCRIBBLESLM_DB_PATH=~/.scribbleslm/scribbleslm.db

# Public embedding path — Voyage (default; fast, contextual)
VOYAGE_API_KEY=your_voyage_key
VOYAGE_MODEL=voyage-context-3
VOYAGE_FALLBACK_MODEL=voyage-4-lite   # $0.02/M + 200M free (NOT 3.5: legacy, no free tier)
VOYAGE_CONCURRENCY=1          # R1 seam; raise in Milestone B
VOYAGE_TPM_CEILING=3000000    # context-3 Tier-1 token budget

# Private embedding path — local bge-m3 GGUF via llama-cpp-python (never leaves host)
PRIVATE_EMBEDDING_MODEL_PATH=~/.scribbleslm/models/bge-m3-Q5_K_M.gguf
PRIVATE_EMBEDDING_THREADS=4

# Private-path contextualization (DeepSeek / any OpenAI-compatible API)
CONTEXT_LLM_BASE_URL=https://api.deepseek.com/v1
CONTEXT_LLM_API_KEY=your_deepseek_key
CONTEXT_LLM_MODEL=deepseek-v4-flash

# Routing default: public unless a source is flagged private=true
DEFAULT_PRIVATE=false

# Security
# SCRIBBLESLM_DOCUMENTS_ROOT=~/.scribbleslm/documents  # local file paths must resolve inside this dir (default: no jail)
SCRIBBLESLM_MAX_DOCUMENT_BYTES=52428800  # 50 MB (0 = unlimited, not recommended)

# Reranker (Milestone C) — DEFAULT OFF (token cost + latency)
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3   # local private reranker (self-exiting subprocess)
RERANKER_IDLE_EXIT=120
VOYAGE_RERANK_MODEL=rerank-2.5           # public reranker
